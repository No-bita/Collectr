# Copy to .env and fill in. Template names must match WhatsApp Manager.

# Collection nudge: same template for every doc; use {{DOC}} or {DOC} for the next required item’s label (e.g. PAN card).
# Default (if unset): "Please send {{DOC}} as a clear photo or PDF in this chat."
# WHATSAPP_COLLECTION_PROMPT=Please upload {{DOC}} here as a photo or PDF. Thank you!

# Meta sample template (fixed body — use 0 body params). Swap for your own later with 1–3 vars if needed.
WHATSAPP_NEW_LEAD_TEMPLATE=hello_world
WHATSAPP_NEW_LEAD_TEMPLATE_LANG=en_US
WHATSAPP_NEW_LEAD_BODY_PARAM_COUNT=0

WHATSAPP_FOLLOW_UP_TEMPLATE=hello_world
WHATSAPP_FOLLOW_UP_TEMPLATE_LANG=en_US
WHATSAPP_FOLLOW_UP_BODY_PARAM_COUNT=0

# Follow-up “Due” on dashboard: hours since sheet “Last updated” with pending docs
FOLLOW_UP_IDLE_HOURS=48
# After team logs follow-up, suppress Due for this many hours
FOLLOW_UP_TEAM_COOLDOWN_HOURS=72

# Document validation upload OCR pipeline
# Endpoint: POST /api/document-validations/validate-upload (multipart/form-data)
# Required form fields: expectedDocumentType (aadhaar|pan), file
OCR_PIPELINE_COMMAND=python3
OCR_PIPELINE_ARGS=["scripts/paddle_ocr_extract.py","--file","{file}"]
PADDLE_OCR_LANG=en
DOC_VALIDATION_MAX_UPLOAD_BYTES=15728640

# Sarvam Document Intelligence OCR (alternative pipeline)
# To try Sarvam instead of Paddle, set:
# pip install sarvamai
# OCR_PIPELINE_ARGS=["scripts/sarvam_ocr_extract.py","--file","{file}"]
# SARVAM_API_SUBSCRIPTION_KEY=your_key_here
# SARVAM_DOC_LANGUAGE=en-IN
# SARVAM_DOC_OUTPUT_FORMAT=md  # allowed: md, html
# SARVAM_POLL_INTERVAL_SECONDS=2
# SARVAM_POLL_TIMEOUT_SECONDS=120

# WhatsApp -> Drive -> dashboard OCR enrichment
# Runs Sarvam OCR right after media is uploaded to Drive and stores extracted fields in documentsState.
# SARVAM_OCR_ENABLED=true
# SARVAM_OCR_COMMAND=.venv/bin/python
# SARVAM_OCR_ARGS=["scripts/sarvam_ocr_extract.py","--file","{file}"]
# Note: sarvam_ocr_extract.py is currently in raw output mode for evaluation.
